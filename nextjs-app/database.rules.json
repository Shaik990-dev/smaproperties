{
  "_README": [
    "Firebase Realtime Database security rules for SMA Properties.",
    "",
    "HOW TO APPLY:",
    "1. Go to Firebase Console → Realtime Database → Rules tab",
    "2. Replace the existing rules with the contents of the 'rules' object below",
    "   (do NOT copy this _README key — Firebase will reject it)",
    "3. Click Publish",
    "",
    "PATHS COVERED:",
    "- /properties         public read; admin write",
    "- /deletedProperties  admin read/write only",
    "- /visitors           anyone write (page visit tracking); admin read",
    "- /propertyViews      anyone read/write (view counter, non-sensitive)",
    "- /users              owner read/write own node; admin read/write all",
    "- /inquiries          anyone create new (contact form); admin read/update/delete",
    "- /emailOtps          blocked from client (server-only via Admin SDK)",
    "- /otpRateLimit       blocked from client (server-only via Admin SDK)",
    "",
    "ADMIN DETECTION:",
    "Rules check root.child('users').child(auth.uid).child('isAdmin').val() === true"
  ],
  "rules": {
    "properties": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true"
    },
    "deletedProperties": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true",
      ".write": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true"
    },
    "visitors": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true",
      "$visit": {
        ".write": "!data.exists() && newData.hasChildren(['time'])"
      }
    },
    "propertyViews": {
      ".read": true,
      ".write": true
    },
    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true)"
      }
    },
    "inquiries": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true",
      "$id": {
        ".write": "(!data.exists() && newData.hasChildren(['name', 'phone', 'createdAt'])) || (auth != null && root.child('users').child(auth.uid).child('isAdmin').val() === true)"
      }
    },
    "emailOtps": {
      ".read": false,
      ".write": false
    },
    "otpRateLimit": {
      ".read": false,
      ".write": false
    }
  }
}
